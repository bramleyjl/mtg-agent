MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mtg_agent
DECKS_CONFIG=/path/to/decks.yaml

# URL of the notion-mcp HTTP server; deck syncs call it to update Notion pages
NOTION_MCP_URL=http://localhost:8766/mcp

# Transport: "sse" for pangolin (HTTP server), "stdio" for local fallback
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8765
