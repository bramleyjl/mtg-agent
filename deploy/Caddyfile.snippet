# Add this block to /etc/caddy/Caddyfile on pangolin.
#
# TLS options (pick one):
#   A) Tailscale (recommended): install Tailscale on both machines, then replace
#      the address with your Tailscale hostname (e.g. pangolin.tail-xyz.ts.net)
#      and add `tls { get_certificate tailscale }` — Caddy handles certs automatically.
#
#   B) HTTP on LAN only: leave as-is. Claude Code connects to http://YOUR_SERVER_IP:8765
#      without going through Caddy at all (skip this file).
#
#   C) Self-signed local CA: use `caddy trust` to generate a local root cert,
#      install it in your system trust store, then use `tls internal` below.

# Option A — with Tailscale hostname:
# pangolin.tail-xyz.ts.net {
#     tls { get_certificate tailscale }
#     reverse_proxy localhost:8765
# }

# Option B — plain HTTP on LAN (Caddy not needed, connect directly):
# http://YOUR_SERVER_IP:8765 { ... }  # just run the server directly on port 8765

# Option C — local CA:
# :8766 {
#     tls internal
#     reverse_proxy localhost:8765
# }
